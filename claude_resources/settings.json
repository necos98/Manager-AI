{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"$(cygpath -w \"$(pwd)\")\\.claude\\scripts\\notify-hook.ps1\" -DefaultTitle \"Claude finished\" -DefaultMessage \"Response complete\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"$(cygpath -w \"$(pwd)\")\\.claude\\scripts\\notify-hook.ps1\" -DefaultTitle \"Claude attention\" -DefaultMessage \"Awaiting input\""
          }
        ]
      }
    ]
  }
}
